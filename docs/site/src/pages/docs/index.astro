---
import Layout from "../../layouts/Layout.astro";
import { docPages } from "../../lib/docs";

const base = import.meta.env.BASE_URL;
const href = (slug: string) => `${base}${base.endsWith("/") ? "" : "/"}docs/${slug}/`;

const groups: Array<{ name: string; match: (slug: string) => boolean }> = [
  { name: "Start here", match: (s) => s === "readme" || s === "quickstart" },
  {
    name: "Guides",
    match: (s) => !s.includes("/") && !s.includes(".zh_") && s !== "readme" && s !== "quickstart",
  },
  { name: "Security", match: (s) => s.startsWith("security/") },
  { name: "Translations (zh_CN / zh_TW)", match: (s) => s.includes(".zh_") },
  { name: "Architecture Decision Records", match: (s) => s.startsWith("adr/") },
];

const grouped = groups.map((g) => ({
  name: g.name,
  pages: docPages.filter((p) => g.match(p.slug)),
}));
---

<Layout title="Documentation">
  <h1>chromium-bridge documentation</h1>
  <p>
    The documentation for
    <a href="https://github.com/Vivswan/chromium-bridge">chromium-bridge</a>, an
    authenticated MCP bridge to your real Chromium browsers, rendered straight
    from the repository's markdown.
  </p>
  {
    grouped.map((group) => (
      <section>
        <h2>{group.name}</h2>
        <ul>
          {group.pages.map((page) => (
            <li>
              <a href={href(page.slug)}>{page.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Layout>
