---
// One layout for every page: a small header, a content column, and enough
// typographic defaults that raw markdown reads well without a CSS framework.
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | chromium-bridge` : "chromium-bridge"}</title>
    <style>
      :root {
        color-scheme: light dark;
      }
      body {
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          sans-serif;
        line-height: 1.6;
        margin: 0;
      }
      header {
        border-bottom: 1px solid color-mix(in srgb, currentColor 20%, transparent);
        padding: 0.75rem 1.25rem;
      }
      header a {
        font-weight: 600;
        text-decoration: none;
        color: inherit;
      }
      main {
        max-width: 46rem;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 4rem;
      }
      main :global(pre) {
        overflow-x: auto;
        padding: 0.75rem 1rem;
        border-radius: 6px;
      }
      main :global(table) {
        border-collapse: collapse;
        display: block;
        overflow-x: auto;
      }
      main :global(th),
      main :global(td) {
        border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
        padding: 0.3rem 0.6rem;
        text-align: left;
      }
      main :global(code) {
        font-size: 0.925em;
      }
    </style>
  </head>
  <body>
    <header>
      <a href={base}>chromium-bridge docs</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
