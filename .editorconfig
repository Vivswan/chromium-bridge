root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Rust: rustfmt uses 4-space indent
[*.rs]
indent_size = 4

# JS/TS/JSON/HTML/CSS: 2-space (Prettier)
[*.{js,mjs,ts,json,html,css}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Markdown: keep trailing whitespace (hard line breaks)
[*.md]
trim_trailing_whitespace = false
