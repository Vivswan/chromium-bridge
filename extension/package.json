{
  "name": "chromium-bridge-extension",
  "version": "0.1.0",
  "private": true,
  "description": "MV3 extension for chromium-bridge - built with WXT.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@chromium-bridge/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "happy-dom": "^20.4.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.13"
  }
}
