{
  "name": "chromium-bridge-extension",
  "version": "0.1.0",
  "private": true,
  "description": "MV3 extension for chromium-bridge - bundled from TypeScript with esbuild.",
  "type": "module",
  "scripts": {
    "build": "bun build.ts",
    "watch": "bun build.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@chromium-bridge/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.2.2",
    "esbuild": "^0.25.0"
  }
}
