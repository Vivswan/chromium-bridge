{
  "name": "chromium-bridge",
  "private": true,
  "description": "Authenticated MCP bridge to your real Chromium browsers - bun workspace root.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "extension",
    "packages/*",
    "tests"
  ],
  "scripts": {
    "gen": "bun scripts/gen-ops.ts && biome format --write extension/src/shared/ops.ts",
    "typecheck": "tsc -p extension && tsc -p tests && tsc -p scripts && tsc -p packages/shared",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test": "bun run --cwd extension test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "typescript": "7.0.2"
  }
}
