{
  "name": "chromium-bridge",
  "private": true,
  "description": "Authenticated MCP bridge to your real Chromium browsers - bun workspace root.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "src/apps/extension",
    "src/apps/desktop/ui",
    "src/packages/*",
    "tests/browser",
    "scripts",
    "src/apps/web"
  ],
  "scripts": {
    "gen": "moon run gen",
    "typecheck": "moon run typecheck",
    "build": "moon run build",
    "lint": "moon run lint-ts",
    "format": "moon run fmt-ts",
    "format:check": "moon run fmt-check-ts",
    "check": "moon run check-ts",
    "test": "moon run test-ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "typescript": "7.0.2"
  },
  "overrides": {
    "adm-zip": "^0.6.0",
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6"
  }
}
